{
    "name": "jj",
    "version": "3.0.0-rc.9",
    "description": "A minimal DOM manipulation library with web components",
    "keywords": [
        "javascript",
        "language",
        "DOM",
        "typescript",
        "imperative programming",
        "no-build",
        "ai-friendly",
        "llm-optimized",
        "cursor-rules",
        "zero-dependency"
    ],
    "type": "module",
    "main": "./lib/index.js",
    "unpkg": "./lib/bundle.js",
    "exports": {
        "import": "./lib/bundle.js",
        "require": "./lib/bundle.cjs"
    },
    "directories": {
        "lib": "lib",
        "doc": "doc",
        "test": "test"
    },
    "files": [
        "lib",
        "skills"
    ],
    "scripts": {
        "fmt": "prettier --write .",
        "lint": "eslint",
        "typecheck": "tsc --noEmit",
        "test": "node --import tsx --test",
        "test:watch": "node --import tsx --test --watch",
        "test:coverage": "node --import tsx --test --experimental-test-coverage",
        "doc": "typedoc src/index.ts",
        "prebuild": "rm -rf lib doc",
        "build": "tsup --dts && npm run doc",
        "get-bundle-size": "gzip -9 -c lib/bundle.min.js | wc -c | numfmt --to=iec-i --suffix=B",
        "preversion": "npm run typecheck && npm run fmt && npm test",
        "prepublishOnly": "npm run build"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/alexewerlof/jj.git"
    },
    "author": "Alex Ewerlöf",
    "license": "MIT",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/jsdom": "^28.0.1",
        "@types/node": "^25.5.2",
        "eslint": "^10.2.0",
        "globals": "^17.4.0",
        "jiti": "^2.6.1",
        "jsdom": "^29.0.2",
        "jty": "^6.1.6",
        "prettier": "^3.6.2",
        "tsup": "^8.5.1",
        "tsx": "^4.20.6",
        "typedoc": "^0.28.18",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.58.1"
    }
}
